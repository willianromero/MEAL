# Configuración de Supabase para el Sistema MEAL Offline-First
# Reemplaza los siguientes valores con los datos de tu proyecto en Supabase.
# Renombra este archivo a ".env" o ".env.local" para que Vite lo detecte.

VITE_SUPABASE_URL=TU_SUPABASE_URL_AQUI
VITE_SUPABASE_ANON_KEY=TU_SUPABASE_ANON_KEY_AQUI
